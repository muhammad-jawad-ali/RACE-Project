# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# OS / IDE
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Environments
venv/
.venv/
env/
.env

# Jupyter
.ipynb_checkpoints/

# --- Project Specific Data ---
# Ignore raw data files as they are very large
data/raw/
*.csv

# Exceptions: Allow the processed test data if needed for the app's random loader
# !data/processed/test.csv

# --- Models & Metrics ---
# We ignore the large .pkl binaries to keep the repo clean, 
# BUT we must keep the JSON metrics for the Streamlit dashboard to work.
models/*.pkl
models/*.joblib
models/*.h5

# DO NOT ignore metrics and confusion matrices (required for UI)
!models/*.json

# --- Clutter / Extra Files ---
# These are draft/temp folders identified as extra
reference/
eda_outputs/
split_data.py
eda_analysis.py
rubric.md

# Log files
*.log
